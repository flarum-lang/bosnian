{
	"name": "flarum-lang/bosnian",
	"type": "flarum-extension",
	"description": "Bosnian language pack for Flarum.",
	"homepage": "https://github.com/flarum-lang/bosnian",
	"keywords": [
		"locale",
		"flarum",
		"flarum-locale",
		"bs-locale",
		"bosnian-locale",
		"bosnian"
	],
	"license": "MIT",
	"support": {
		"issues": "https://github.com/flarum-lang/bosnian/issues",
		"source": "https://github.com/flarum-lang/bosnian"
	},
	"require": {
		"flarum/core": "^2.0"
	},
	"minimum-stability": "dev",
	"prefer-stable": true,
	"extra": {
		"flarum-extension": {
			"title": "Bosnian",
			"category": "language",
			"icon": {
				"image": "icon.svg",
				"backgroundSize": "cover",
				"backgroundPosition": "center"
			}
		},
		"flarum-locale": {
			"code": "bs",
			"title": "Bosnian"
		},
		"extiverse": {
			"discuss": ""
		},
		"branch-alias": {
			"dev-master": "1.x-dev"
		}
	}
}
